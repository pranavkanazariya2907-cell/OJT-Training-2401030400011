<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Website</title>
  <!-- Font Awesome for icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
    }
    header {
      background-color: lightpink;
      padding: 15px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .logo img {
      height: 40px;
    }
    .searchbar {
      display: flex;
      align-items: center;
      width: 200px;
      margin-left: auto;
    }
    .searchbar input {
      padding: 6px;
      border: none;
      border-radius: 4px 0 0 4px;
      outline: none;
      flex: 1;
    }
    .searchbar button {
      padding: 6px 10px;
      border: none;
      border-radius: 0 4px 4px 0;
      cursor: pointer;
      background: #333;
      color: #fff;
    }
    .icons {
      display: flex;
      gap: 15px;
      margin-left: 15px;
    }
    .icons a {
      font-size: 18px;
      color: #333;
      text-decoration: none;
      transition: color 0.3s;
      cursor: pointer;
    }
    .icons a:hover {
      color: #000;
    }
    .navbar {
      display: flex;
      justify-content: space-around;
      align-items: center;
      padding: 10px;
      background-color: #f8f8f8;
    }
    .navbar div {
      display: flex;
      align-items: center;
      gap: 6px;
      cursor: pointer;
    }
    .navbar div:hover {
      text-decoration: underline;
    }
    .categorybar {
      display: flex;
      justify-content: center;
      align-items: center;
      background: linear-gradient(to right, #ffe0cc, #ffd6d6);
      padding: 12px 0;
      gap: 20px;
      flex-wrap: wrap;
    }
    .categorybar a {
      text-decoration: none;
      color: #333;
      font-weight: 600;
      padding: 6px 12px;
      border-radius: 20px;
      transition: all 0.3s ease;
    }
    .categorybar a:hover {
      background-color: #ff7f50;
      color: white;
      transform: scale(1.05);
    }
    .categorybar a.active {
      background-color: #ff7f50;
      color: white;
    }
    .slider {
      background-image: url("C:/Users/DELL/Downloads/img.jpeg");
    }
    /* Modal Base */
    .modal {
      display: none;
      position: fixed;
      z-index: 1000;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      overflow: auto;
      background: rgba(0,0,0,0.5);
    }
    .modal-content {
      background: white;
      margin: 10% auto;
      padding: 30px;
      border-radius: 8px;
      width: 300px;
      text-align: center;
      box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    }
    .modal-content h2 {
      margin-bottom: 20px;
      color: #333;
    }
    .modal-content input {
      width: 100%;
      padding: 10px;
      margin: 8px 0;
      border: 1px solid #ccc;
      border-radius: 4px;
      outline: none;
    }
    .modal-content button {
      width: 100%;
      padding: 10px;
      background: #ff7f50;
      border: none;
      border-radius: 4px;
      color: white;
      font-weight: bold;
      cursor: pointer;
      transition: background 0.3s;
    }
    .modal-content button:hover {
      background: #e5673f;
    }
    .close {
      color: #aaa;
      float: right;
      font-size: 24px;
      font-weight: bold;
      cursor: pointer;
    }
    .close:hover {
      color: #000;
    }
    .modal-content a {
      display: block;
      margin-top: 12px;
      font-size: 14px;
      color: #333;
      text-decoration: none;
    }
    .modal-content a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header>
    <div class="logo">
      <h1>HB Lifestyle</h1>
    </div>
    <div class="searchbar">
      <input type="text" placeholder="Search">
      <button>Go</button>
    </div>
    <div class="icons">
      <a href="#" title="Wishlist"><i class="fas fa-heart"></i></a>
      <a href="#" title="Cart"><i class="fas fa-shopping-cart"></i></a>
      <a id="signinBtn" title="Sign In"><i class="fas fa-user"></i></a>
    </div>
  </header>

  <!-- Navbar -->
  <nav class="navbar">
    <div>🚚 Free Shipping</div>
    <div>🛍️ Click & Collect</div>
    <div>🔒 Return to Store</div>
    <div>📍 Delivering To</div>
    <div>❓ Help</div>
  </nav>

  <!-- Category Bar -->
  <nav class="categorybar">
    <a href="#" class="active">Women</a>
    <a href="#">Men</a>
    <a href="#">Kids</a>
    <a href="#">Footwear</a>
    <a href="#">Bags</a>
    <a href="#">Beauty</a>
    <a href="#">Home & Living</a>
    <a href="#">Babyshop</a>
    <a href="#">Gen Z</a>
    <a href="#">Watches</a>
    <a href="#">LUXE</a>
  </nav>

  <!-- Slider -->
  <div class="slider">
    <img src="C:/Users/DELL/Downloads/w img.jpeg" alt="myimage" height="450px" width="1600px">
  </div>

  <!-- Login Modal -->
  <div id="loginModal" class="modal">
    <div class="modal-content">
      <span class="close">&times;</span>
      <h2>Sign In</h2>
      <form>
        <input type="text" placeholder="Username" required>
        <input type="password" placeholder="Password" required>
        <button type="submit">Login</button>
      </form>
      <a href="#">Forgot Password?</a>
      <a id="createAccountLink" href="#">Create Account</a>
    </div>
  </div>

  <!-- Create Account Modal -->
  <div id="createModal" class="modal">
    <div class="modal-content">
      <span class="close">&times;</span>
      <h2>Create Account</h2>
      <form>
        <input type="text" placeholder="Username" required>
        <input type="email" placeholder="Email" required>
        <input type="password" placeholder="Password" required>
        <button type="submit">Register</button>
      </form>
    </div>
  </div>

  <script>
    const loginModal = document.getElementById("loginModal");
    const createModal = document.getElementById("createModal");
    const signinBtn = document.getElementById("signinBtn");
    const closeButtons = document.querySelectorAll(".close");
    const createLink = document.getElementById("createAccountLink");

    // Open login modal
    signinBtn.onclick = function() {
      loginModal.style.display = "block";
    }

    // Close modals
    closeButtons.forEach(btn => {
      btn.onclick = function() {
        loginModal.style.display = "none";
        createModal.style.display = "none";
      }
    });

    // Open create account modal
    createLink.onclick = function(e) {
      e.preventDefault();
      loginModal.style.display = "none";
      createModal.style.display = "block";
    }

    // Close when clicking outside
    window.onclick = function(event) {
      if (event.target == loginModal) {
        loginModal.style.display = "none";
      }
      if (event.target == createModal) {
        createModal.style.display = "none";
      }
    }
  </script>
</body>
</html>
