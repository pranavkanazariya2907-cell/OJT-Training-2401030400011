var fiveDaysAgo = new Date();
fiveDaysAgo.setDate(fiveDaysAgo.getDate() - 5);

db.orders.aggregate([
{
    $match: {
        orderDate: { $gte: fiveDaysAgo }
    }
},
{
    $lookup: {
        from: "customers",
        localField: "customerId",
        foreignField: "customerId",
        as: "customerInfo"
    }
}
])
