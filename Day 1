<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>website</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
    }
    header {
    background-color: lightsalmon;
      padding: 15px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .logo img {
      height: 40px; /* adjust size */
    }
    .searchbar {
      display: flex;
      align-items: center;
    }
    .searchbar input {
      padding: 6px;
      border: none;
      border-radius: 4px 0 0 4px;
      outline: none;
    }
    .searchbar button {
      padding: 6px 10px;
      border: none;
      border-radius: 0 4px 4px 0;
      cursor: pointer;
    }
    .navbar {
      display: flex;
      justify-content: space-around;
      align-items: center;
      padding: 10px;
    }
    .navbar div {
      display: flex;
      align-items: center;
      gap: 6px;
      cursor: pointer;
    }
    .navbar div:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <header>
    <div class="logo">
      <h1>Lifestyle</h1>
    </div>
    <div class="searchbar">
      <input type="text" placeholder="Search products...">
      <button>Search</button>
    </div>
</header>

  </header>

  <div class="navbar">
    <div>🚚 Free Shipping</div>
    <div>🛍️ Click & Collect</div>
    <div>🔒 Return to Store</div>
    <div>📍 Delivering To</div>
    <div>❓ Help</div>
  </div>
</body>
</html>
