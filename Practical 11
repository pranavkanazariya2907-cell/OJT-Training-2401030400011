<!DOCTYPE html>
<html>
<head>
    <title>Zebra Stripe Table</title>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <style>
        table {
            border-collapse: collapse;
            width: 50%;
            margin: 20px auto;
        }

        th, td {
            border: 1px solid black;
            padding: 10px;
            text-align: center;
        }

        th {
            background-color: gray;
            color: white;
        }

        .odd {
            background-color: lightblue;
        }

        .even {
            background-color: lightgreen;
        }
    </style>
</head>
<body>

<h2 align="center">Zebra Stripe Table</h2>

<table>
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>City</th>
    </tr>

    <tr>
        <td>1</td>
        <td>Heer</td>
        <td>Ahmedabad</td>
    </tr>

    <tr>
        <td>2</td>
        <td>Rahul</td>
        <td>Surat</td>
    </tr>

    <tr>
        <td>3</td>
        <td>Priya</td>
        <td>Vadodara</td>
    </tr>

    <tr>
        <td>4</td>
        <td>Amit</td>
        <td>Rajkot</td>
    </tr>
</table>

<script>
$(document).ready(function(){
    $("table tr:odd").addClass("odd");
    $("table tr:even").addClass("even");
});
</script>

</body>
</html>
