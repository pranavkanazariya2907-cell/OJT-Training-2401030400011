    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  // ── DATA ──
  const products = [
    {
      id: 1, tag: 'rare', era: '1920s · Art Deco',
      name: 'Bakelite Mantle Clock', badge: 'Rare',
      desc: 'Original Art Deco mantle clock in warm amber bakelite. Eight-day movement, fully serviced. Minor patina consistent with age.',
      price: '£485', origPrice: '£620',
      condition: 'Excellent', origin: 'England', year: 'c. 1924', material: 'Bakelite',
      img: 'https://images.unsplash.com/photo-1484502249930-e6f6c5ba8b02?w=600&q=80',
      category: ['all', 'rare']
    },
    {
      id: 2, tag: 'new', era: '1950s · Mid-Century',
      name: 'Leica IIIf 35mm Camera', badge: 'New',
      desc: 'Legendary Leica IIIf with 50mm Elmar f/3.5 collapsible lens. Recently CLA'd. All speeds accurate. Light seals replaced.',
      price: '£1,240',
      condition: 'Very Good', origin: 'Germany', year: '1952', material: 'Brass & Steel',
      img: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=80',
      category: ['all', 'new', 'retro']
    },
    {
      id: 3, tag: 'sale', era: '1880s · Victorian',
      name: 'Mahogany Writing Slope', badge: 'Sale',
      desc: 'Gentleman\'s portable writing slope in figured mahogany with brass fittings, velvet interior and secret compartment. Excellent original condition.',
      price: '£320', origPrice: '£450',
      condition: 'Good+', origin: 'Scotland', year: 'c. 1885', material: 'Mahogany & Brass',
      img: 'https://images.unsplash.com/photo-1567225557594-88d73e55f2cb?w=600&q=80',
      category: ['all', 'sale', 'victorian']
    },
    {
      id: 4, tag: 'new', era: '1960s · Space Age',
      name: 'Ericofon Cobra Telephone', badge: 'New',
      desc: 'Iconic Swedish Ericofon in original harvest gold. Fully working, dial mechanism smooth. A design icon of the Space Age era.',
      price: '£285',
      condition: 'Excellent', origin: 'Sweden', year: '1965', material: 'ABS Plastic',
      img: 'https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=600&q=80',
      category: ['all', 'new', 'retro']
    },
    {
      id: 5, tag: 'rare', era: '1890s · Victorian',
      name: 'Stereoscope Viewer & Cards', badge: 'Rare',
      desc: 'Holmes-pattern stereoscope in rosewood with a collection of 48 original albumen print cards depicting European cities. Museum quality.',
      price: '£680',
      condition: 'Excellent', origin: 'USA', year: 'c. 1892', material: 'Rosewood & Brass',
      img: 'https://images.unsplash.com/photo-1584847801557-a4c90c6ccb9f?w=600&q=80',
      category: ['all', 'rare', 'victorian']
    },
    {
      id: 6, tag: 'sale', era: '1930s · Art Deco',
      name: 'Sunburst Wall Mirror', badge: 'Sale',
      desc: 'Spectacular Art Deco sunburst mirror in gilt gesso with original glass. Some foxing to mirror plate adds authentic patina. 86cm diameter.',
      price: '£540', origPrice: '£720',
      condition: 'Good', origin: 'France', year: 'c. 1932', material: 'Gilt Gesso & Glass',
      img: 'https://images.unsplash.com/photo-1522444195799-478538b28823?w=600&q=80',
      category: ['all', 'sale']
    },
  ];

  let cart = [];
  let currentProduct = null;
  let activeFilter = 'all';

  // ── RENDER PRODUCTS ──
  function renderProducts(filter = 'all') {
    const grid = document.getElementById('productsGrid');
    const filtered = products.filter(p => p.category.includes(filter));
    grid.innerHTML = filtered.map(p => `
      <div class="product-card reveal" data-id="${p.id}">
        <div class="product-img-wrap">
          <img src="${p.img}" alt="${p.name}" loading="lazy">
          <span class="product-badge ${p.tag}">${p.badge}</span>
          <div class="product-actions">
            <button class="icon-btn" onclick="openModal(${p.id})" title="Quick view">👁</button>
            <button class="icon-btn" onclick="addToCart(${p.id})" title="Add to cart">+</button>
          </div>
        </div>
        <div class="product-body">
          <div class="product-era">${p.era}</div>
          <div class="product-name">${p.name}</div>
          <p class="product-desc">${p.desc.substring(0,90)}…</p>
          <div class="product-footer">
            <div>
              <span class="product-price">${p.price}</span>
              ${p.origPrice ? `<span class="product-price-orig">${p.origPrice}</span>` : ''}
            </div>
            <button class="btn-add" onclick="addToCart(${p.id})">Add to Cart</button>
          </div>
        </div>
      </div>
    `).join('');
    observeReveal();
  }

  function filterProducts(filter, btn) {
    activeFilter = filter;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderProducts(filter);
  }

  // ── CART ──
  function addToCart(id) {
    const p = products.find(x => x.id === id);
    cart.push(p);
    document.getElementById('cartBadge').textContent = cart.length;
    showToast(`"${p.name}" added to cart`);
  }

  function addToCartModal() {
    if (currentProduct) {
      addToCart(currentProduct.id);
      closeModalBtn();
    }
  }

  function openCart() {
    if (cart.length === 0) {
      showToast('Your cart is empty');
    } else {
      showToast(`${cart.length} item${cart.length > 1 ? 's' : ''} in your cart`);
    }
  }

  // ── MODAL ──
  function openModal(id) {
    const p = products.find(x => x.id === id);
    currentProduct = p;
    document.getElementById('modalImgSrc').src = p.img;
    document.getElementById('modalEra').textContent = p.era;
    document.getElementById('modalTitle').textContent = p.name;
    document.getElementById('modalDesc').textContent = p.desc;
    document.getElementById('modalPrice').textContent = p.price;
    document.getElementById('modalDetails').innerHTML = `
      <div class="detail-item"><div class="detail-label">Condition</div><div class="detail-val">${p.condition}</div></div>
      <div class="detail-item"><div class="detail-label">Origin</div><div class="detail-val">${p.origin}</div></div>
      <div class="detail-item"><div class="detail-label">Year</div><div class="detail-val">${p.year}</div></div>
      <div class="detail-item"><div class="detail-label">Material</div><div class="detail-val">${p.material}</div></div>
    `;
    document.getElementById('modalOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModalBtn() {
    document.getElementById('modalOverlay').classList.remove('open');
    document.body.style.overflow = '';
    currentProduct = null;
  }

  function closeModal(e) {
    if (e.target === document.getElementById('modalOverlay')) closeModalBtn();
  }

  // ── TOAST ──
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3000);
  }

  // ── NEWSLETTER ──
  function subscribeNewsletter() {
    const input = document.getElementById('emailInput');
    if (input.value && input.value.includes('@')) {
      showToast('Welcome to the Inner Circle ✦');
      input.value = '';
    } else {
      showToast('Please enter a valid email');
    }
  }

  // ── NAV SCROLL ──
  window.addEventListener('scroll', () => {
    document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 20);
  });

  // ── MOBILE MENU ──
  function toggleMenu() {
    document.getElementById('mobileMenu').classList.toggle('open');
  }

  // ── SCROLL REVEAL ──
  function observeReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) {
          setTimeout(() => e.target.classList.add('visible'), i * 80);
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.reveal').forEach(el => {
      el.classList.remove('visible');
      observer.observe(el);
    });
  }

  // ── INIT ──
  renderProducts('all');
  observeReveal();

  // Keyboard close modal
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeModalBtn();
  });
</script>
</body>
