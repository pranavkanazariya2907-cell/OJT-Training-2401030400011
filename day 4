<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Asthetic Soles</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background-color: #1f75c0;
    }

    /* Header Section */
    .header {
      background-color: #1e1e1e;
      color: white;
      text-align: center;
      padding: 40px 0 20px;
    }

    .header h1 {
      font-size: 40px;
      margin: 0;
    }

    .header p {
      font-size: 18px;
      margin-top: 10px;
      color: #dcdcdc;
    }

    /* Sneaker Section */
    .sneaker-section {
      background-color: #f5f5f5;
      text-align: center;
      padding: 40px 0;
    }

    .sneaker-section h2 {
      color: #b37400;
      font-size: 30px;
      margin-bottom: 15px;
    }

    .nav-links {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 25px;
      font-weight: bold;
      font-size: 18px;
      color: #000;
    }

    .nav-links a {
      text-decoration: none;
      color: #000;
      transition: color 0.3s ease;
    }

    .nav-links a:hover {
      color: #b37400;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Welcome to Asthetic Soles</h1>
    <p>Your step into style</p>
  </div>

  <div class="sneaker-section">
    <h2>Classic Sneakers</h2>
    <div class="nav-links">
      <a href="#">New & Feature</a>
      <a href="#">Men</a>
      <a href="#">Women</a>
      <a href="#">Kids</a>
      <a href="#">Jordan</a>
      <a href="#">Sale</a>
    </div>
  </div>
</body>
</html>
