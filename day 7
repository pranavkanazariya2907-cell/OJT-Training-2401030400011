  <section class="contact py-5" id="contact">
    <div class="container">
      <h2 class="section-title text-center mb-5">Contact Us</h2>
      <div class="row g-5">
        <div class="col-lg-6">
          <h4 class="mb-4">Get In Touch</h4>
          <p><strong>Phone:</strong> +91 98765 43210</p>
          <p><strong>Email:</strong> support@iraasoles.com</p>
          <p><strong>Instagram:</strong> @iraasoles</p>
          <p><strong>Working Hours:</strong> 10 AM - 9 PM</p>
        </div>
        <div class="col-lg-6">
          <form class="contact-form">
            <div class="mb-3">
              <input type="text" class="form-control" placeholder="Your Name" required>
            </div>
            <div class="mb-3">
              <input type="email" class="form-control" placeholder="Your Email" required>
            </div>
            <div class="mb-3">
              <textarea rows="5" class="form-control" placeholder="Your Message"></textarea>
            </div>
            <button type="submit" class="contact-btn w-100">
              <i class="bi bi-send me-2"></i>Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="py-5 bg-white text-center" id="location">
    <div class="container">
      <h2 class="section-title mb-4">Visit Our Store</h2>
      <p class="fs-5 mb-4">
        Iraa Soles Store <br>
        Sector 7, Gandhinagar, Gujarat, India
      </p>
      <div class="map-container">
        <iframe
          src="https://maps.google.com/maps?q=Gandhinagar&t=&z=13&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy">
        </iframe>
      </div>
    </div>
  </section>

  <!-- AUTHENTICATION MODAL -->
  <div class="modal fade" id="authModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-body p-4">
          <div class="modal-header-tabs mb-4">
            <div class="tab-btn active" id="signInTab">
              <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </div>
            <div class="tab-btn" id="createTab">
              <i class="bi bi-person-plus me-2"></i>Create Account
            </div>
          </div>
          <div id="signInForm">
            <div class="mb-3">
              <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-envelope"></i></span>
                <input type="email" class="form-control" placeholder="Email">
              </div>
            </div>
            <div class="mb-3">
              <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-lock"></i></span>
                <input type="password" class="form-control" placeholder="Password">
              </div>
            </div>
            <button class="btn btn-dark w-100">
              <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </button>
          </div>
          <div id="createForm" style="display:none;">
            <div class="mb-3">
              <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-person"></i></span>
                <input type="text" class="form-control" placeholder="Full Name">
              </div>
            </div>
            <div class="mb-3">
              <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-envelope"></i></span>
                <input type="email" class="form-control" placeholder="Email">
              </div>
            </div>
            <div class="mb-3">
              <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-lock"></i></span>
                <input type="password" class="form-control" placeholder="Password">
              </div>
            </div>
            <button class="btn btn-dark w-100">
              <i class="bi bi-person-plus me-2"></i>Create Account
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- PAYMENT / CHECKOUT MODAL -->
  <div class="modal fade" id="paymentModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header border-0 pb-0">
          <h4 class="modal-title fw-bold">Checkout & Payment</h4>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-4">
          <div class="row g-4">
            
            <!-- Left Side: Payment Options -->
            <div class="col-md-7">
              <h5 class="mb-3">Select Payment Method</h5>
              
              <!-- Option 1: Credit / Debit Card -->
              <label class="payment-option d-block w-100">
                <div class="d-flex align-items-center">
                  <input type="radio" name="paymentMethod" class="me-3" checked>
                  <strong><i class="bi bi-credit-card me-2"></i>Credit / Debit Card</strong>
                </div>
                <div class="payment-details">
                  <input type="text" class="form-control mb-2" placeholder="Card Number (0000 0000 0000 0000)">
                  <div class="row g-2">
                    <div class="col-6">
                      <input type="text" class="form-control" placeholder="MM/YY">
                    </div>
                    <div class="col-6">
                      <input type="text" class="form-control" placeholder="CVV">
                    </div>
                  </div>
                  <input type="text" class="form-control mt-2" placeholder="Name on Card">
                </div>
              </label>

              <!-- Option 2: UPI (India Specific) -->
              <label class="payment-option d-block w-100">
                <div class="d-flex align-items-center">
                  <input type="radio" name="paymentMethod" class="me-3">
                  <strong><i class="bi bi-phone me-2"></i>UPI / QR</strong>
                </div>
                <div class="payment-details">
                  <p class="text-muted small mb-2">Enter your UPI ID to receive a payment request.</p>
                  <div class="input-group">
                    <input type="text" class="form-control" placeholder="e.g. yourname@okbank">
                    <button type="button" class="btn btn-outline-dark">Verify</button>
                  </div>
                </div>
              </label>

              <!-- Option 3: Cash on Delivery -->
              <label class="payment-option d-block w-100">
                <div class="d-flex align-items-center">
                  <input type="radio" name="paymentMethod" class="me-3">
                  <strong><i class="bi bi-cash-stack me-2"></i>Cash on Delivery (COD)</strong>
                </div>
                <div class="payment-details">
                  <p class="text-muted small mb-0">Pay with cash when your shoes are delivered to your doorstep. (An additional ₹50 handling fee may apply).</p>
                </div>
              </label>
            </div>

            <!-- Right Side: Order Summary -->
            <div class="col-md-5">
              <div class="bg-light p-3 border-radius-10" style="border-radius: 10px;">
                <h5 class="mb-3">Order Summary</h5>
                <div class="d-flex justify-content-between mb-2">
                  <span class="text-muted">Subtotal</span>
                  <strong>₹8,999</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                  <span class="text-muted">Shipping</span>
                  <strong>Free</strong>
                </div>
                <hr>
                <div class="d-flex justify-content-between mb-4">
                  <span class="fw-bold fs-5">Total</span>
                  <span class="fw-bold fs-5 text-danger">₹8,999</span>
                </div>
                <button type="button" class="btn btn-danger w-100 py-3 fw-bold" id="payNowBtn">
                  <i class="bi bi-lock-fill me-2"></i>Pay ₹8,999 securely
                </button>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>

  <footer class="text-center py-4">
    <p class="mb-1">© 2026 Iraa Soles | All Rights Reserved</p>
    <p class="mb-0">Gandhinagar, Gujarat, India</p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // AUTHENTICATION TABS
    const signInTab = document.getElementById('signInTab');
    const createTab = document.getElementById('createTab');
    const signInForm = document.getElementById('signInForm');
    const createForm = document.getElementById('createForm');

    signInTab.onclick = () => {
      signInTab.classList.add('active');
      createTab.classList.remove('active');
      signInForm.style.display = 'block';
      createForm.style.display = 'none';
    }

    createTab.onclick = () => {
      createTab.classList.add('active');
      signInTab.classList.remove('active');
      createForm.style.display = 'block';
      signInForm.style.display = 'none';
    }

    // PAY NOW BUTTON SIMULATION
    const payNowBtn = document.getElementById('payNowBtn');
    payNowBtn.addEventListener('click', () => {
      payNowBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Processing...';
      payNowBtn.disabled = true;
      
      // Simulate network delay
      setTimeout(() => {
        payNowBtn.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i>Payment Successful!';
        payNowBtn.classList.remove('btn-danger');
        payNowBtn.classList.add('btn-success');
        
        setTimeout(() => {
          // Reset button
          payNowBtn.innerHTML = '<i class="bi bi-lock-fill me-2"></i>Pay ₹8,999 securely';
          payNowBtn.disabled = false;
          payNowBtn.classList.add('btn-danger');
          payNowBtn.classList.remove('btn-success');
          
          // Close modal via Bootstrap API
          const modal = bootstrap.Modal.getInstance(document.getElementById('paymentModal'));
          modal.hide();
        }, 2000);
      }, 2000);
    });
  </script>

</body>
</html>
