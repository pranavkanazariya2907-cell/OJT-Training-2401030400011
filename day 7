        </div>
        <!-- Shoe 2 -->
        <div class="col-md-6 col-lg-4">
          <div class="card h-100">
            <img src="https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?q=80&w=1000&auto=format&fit=crop" class="card-img-top" alt="Nike Airmax 1">
            <div class="card-body text-center">
              <h4>Nike Air Max 1</h4>
              <div class="price mb-3">₹8,599</div>
              <button class="add-cart" data-bs-toggle="modal" data-bs-target="#paymentModal">Buy Now</button>
            </div>
          </div>
        </div>
        <!-- Shoe 3 -->
        <div class="col-md-6 col-lg-4">
          <div class="card h-100">
            <img src="https://images.unsplash.com/photo-1608231387042-66d1773070a5?q=80&w=1000&auto=format&fit=crop" class="card-img-top" alt="Puma Sneaker">
            <div class="card-body text-center">
              <h4>Puma Modern Sneaker</h4>
              <div class="price mb-3">₹3,000</div>
              <button class="add-cart" data-bs-toggle="modal" data-bs-target="#paymentModal">Buy Now</button>
            </div>
          </div>
        </div>
        <!-- Shoe 4 -->
        <div class="col-md-6 col-lg-4">
          <div class="card h-100">
            <img src="https://images.unsplash.com/photo-1552346154-21d32810aba3?q=80&w=1000&auto=format&fit=crop" class="card-img-top" alt="Air Jordan Retro">
            <div class="card-body text-center">
              <h4>Air Jordan Retro High</h4>
              <div class="price mb-3">₹14,995</div>
              <button class="add-cart" data-bs-toggle="modal" data-bs-target="#paymentModal">Buy Now</button>
            </div>
          </div>
        </div>
        <!-- Shoe 5 -->
        <div class="col-md-6 col-lg-4">
          <div class="card h-100">
            <img src="https://images.unsplash.com/photo-1491553895911-0055eca6402d?q=80&w=1000&auto=format&fit=crop" class="card-img-top" alt="Adidas Running Shoes">
            <div class="card-body text-center">
              <h4>Adidas Stealth Sport</h4>
              <div class="price mb-3">₹6,499</div>
              <button class="add-cart" data-bs-toggle="modal" data-bs-target="#paymentModal">Buy Now</button>
            </div>
          </div>
        </div>
        <!-- Shoe 6 -->
        <div class="col-md-6 col-lg-4">
          <div class="card h-100">
            <img src="https://images.unsplash.com/photo-1597045566677-8cf032ed6634?q=80&w=1000&auto=format&fit=crop" class="card-img-top" alt="Urban Streetwear Sneaker">
            <div class="card-body text-center">
              <h4>Urban Sole Streetwear</h4>
              <div class="price mb-3">₹5,299</div>
              <button class="add-cart" data-bs-toggle="modal" data-bs-target="#paymentModal">Buy Now</button>
